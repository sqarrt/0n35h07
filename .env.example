# Env template. Copy to `.env` (gitignored) and fill in values. In CI set these as GitHub Actions secrets
# (Settings → Secrets and variables → Actions) — Vite picks up VITE_* from process.env at build time too.

# TURN credentials for WebRTC (NAT traversal). Without them online only works on simple NATs (STUN-only).
# The relay host is set in code (src/constants.ts), the secret is only these two lines.
# Free credentials: https://dashboard.metered.ca → TURN → TURN Credentials.
# WARNING: on the frontend static credentials are visible in DevTools to any player — env only keeps them out of the repo.
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
