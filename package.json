{
  "name": "oneshot",
  "private": true,
  "version": "0.6.0",
  "description": "OneShot — an arcade first-person shooter, strictly 1v1, peer-to-peer in the browser",
  "author": "Dmitry Shatalov",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/sqarrt/0n35h07#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sqarrt/0n35h07.git"
  },
  "bugs": {
    "url": "https://github.com/sqarrt/0n35h07/issues"
  },
  "keywords": [
    "game",
    "fps",
    "shooter",
    "1v1",
    "multiplayer",
    "webrtc",
    "p2p",
    "three.js",
    "react-three-fiber",
    "rapier",
    "browser-game"
  ],
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --config vite.trailer.config.ts",
    "build:desktop": "tsc -b && vite build --mode tauri",
    "build:steam": "node scripts/build-steam.mjs",
    "upload:steam": "node scripts/upload-steam.mjs",
    "build:trailer": "vite build --config vite.trailer.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "ensure:native": "node scripts/ensure-native.mjs",
    "pretest": "npm run ensure:native",
    "test": "vitest run --config vitest.config.ts && playwright test --project=headless",
    "pretest:unit": "npm run ensure:native",
    "test:unit": "vitest run --config vitest.config.ts",
    "pretest:e2e": "npm run ensure:native",
    "test:e2e": "playwright test --project=headless",
    "test:headed": "playwright test --project=headed",
    "test:connected": "playwright test --project=connected --workers=1",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build"
  },
  "dependencies": {
    "@fontsource/share-tech-mono": "^5.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@strudel/web": "^1.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "nostr-tools": "^2.23.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.8.3",
    "trystero": "^0.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
